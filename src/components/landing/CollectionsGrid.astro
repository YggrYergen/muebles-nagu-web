---

<section id="colecciones" class="py-24 px-6 bg-white overflow-hidden">
  <div class="max-w-7xl mx-auto">
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-8">
      <div class="max-w-2xl">
        <span class="font-sans text-xs tracking-[0.4em] uppercase text-text-coffee/60 mb-4 block">Nuestras Colecciones</span>
        <h2 class="font-serif text-5xl md:text-7xl leading-tight">Mobiliario con <br/> alma y carácter.</h2>
      </div>
      <div class="pb-2">
        <a href="https://instagram.com/mueblesnagu" target="_blank" class="font-sans text-xs tracking-widest uppercase border-b border-accent-gold pb-1 hover:text-accent-gold transition-colors">
          Ver Instagram completo
        </a>
      </div>
    </div>

    <!-- Bento Grid -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-6 auto-rows-[300px] md:auto-rows-[350px]">
      
      <!-- Grande (2x2 equiv) - NOW COCINAS -->
      <div class="md:col-span-8 md:row-span-2 relative group overflow-hidden shadow-luxury">
        <video 
          src="/media/cocina_opt.mp4" 
          autoplay 
          loop 
          muted 
          playsinline 
          class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105 absolute inset-0"
        ></video>
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent flex flex-col justify-end p-8 md:p-12 z-20 pointer-events-none">
          <span class="font-sans text-[10px] tracking-[0.3em] uppercase text-accent-gold mb-2 block">Producto Estrella</span>
          <h3 class="font-serif text-bg-cream text-4xl md:text-5xl mb-4">Cocinas Vivientes</h3>
          <p class="font-sans text-bg-cream/70 max-w-md text-sm leading-relaxed">Islas y espacios diseñados para ser el corazón del hogar.</p>
        </div>
        <div class="absolute top-8 right-8 z-20">
           <div class="w-12 h-12 border border-white/30 rounded-full flex items-center justify-center text-white opacity-0 group-hover:opacity-100 -translate-y-4 group-hover:translate-y-0 transition-all duration-500">
             <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 7h10v10"></path><path d="M7 17 17 7"></path></svg>
           </div>
        </div>
      </div>

      <!-- Alta (1x2 equiv) - NOW CÓMODAS -->
      <div class="md:col-span-4 md:row-span-2 relative group overflow-hidden shadow-luxury">
        <video 
          src="/media/comodas_opt.mp4" 
          autoplay 
          loop 
          muted 
          playsinline 
          class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105 absolute inset-0"
        ></video>
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent flex flex-col justify-end p-8 z-20 pointer-events-none">
          <h3 class="font-serif text-bg-cream text-3xl mb-2">Cómodas de Autor</h3>
          <p class="font-sans text-bg-cream/70 text-sm">Cada veta cuenta una historia. Terminaciones de guante.</p>
        </div>
      </div>

      <!-- Ancha (2x1 equiv) - CLOSETS -->
      <div class="md:col-span-6 md:row-span-1 relative group overflow-hidden shadow-luxury slideshow-container"
           data-images='["/media/closet1.webp", "/media/closet2.webp"]'>
        <img src="/media/closet1.webp" alt="Closets" class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105 active-slide absolute inset-0" />
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent flex flex-col justify-end p-8 z-20 pointer-events-none">
          <h3 class="font-serif text-bg-cream text-3xl">Closets & Organización</h3>
        </div>
      </div>

      <!-- Pequeña (1x1 equiv) - Text/Abstract -->
      <div class="md:col-span-6 md:row-span-1 bg-bg-forest p-10 flex flex-col justify-center shadow-luxury">
        <h3 class="font-serif text-bg-cream text-3xl mb-4">Y mucho más.</h3>
        <p class="font-sans text-bg-cream/60 text-sm mb-8 leading-relaxed">
          Racks, vanitorios, mobiliario de oficina, camas, veladores y nuestra exclusiva línea infantil.
        </p>
        <div class="flex flex-wrap gap-3">
          <span class="px-3 py-1 border border-bg-cream/20 text-bg-cream/80 text-[10px] uppercase tracking-widest text-xs">Muebles de Oficina</span>
          <span class="px-3 py-1 border border-bg-cream/20 text-bg-cream/80 text-[10px] uppercase tracking-widest text-xs">Racks de TV</span>
          <span class="px-3 py-1 border border-bg-cream/20 text-bg-cream/80 text-[10px] uppercase tracking-widest text-xs">Línea Infantil</span>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  function initSlideshows() {
    const containers = document.querySelectorAll('.slideshow-container');
    
    containers.forEach(container => {
      const imagesString = container.getAttribute('data-images');
      if (!imagesString) return;
      
      const images = JSON.parse(imagesString || '[]');
      if (images.length <= 1) return;

      let currentIndex = 0;
      let nextIndex = 1;
      
      const currentImg = container.querySelector('.active-slide');
      if (!currentImg || !(currentImg instanceof HTMLImageElement)) return;
      
      // Create next image element with same classes for consistency, but initially hidden
      const nextImg = document.createElement('img');
      // Copy classes but reset specific styles
      nextImg.className = currentImg.className;
      nextImg.classList.remove('active-slide');
      // Ensure it starts hidden and low z-index
      nextImg.style.opacity = '0';
      nextImg.style.zIndex = '1';
      nextImg.style.transition = 'opacity 1000ms ease-in-out, transform 1000ms';
      
      container.insertBefore(nextImg, container.firstChild); 

      currentImg.style.zIndex = '2';
      currentImg.style.transition = 'opacity 1000ms ease-in-out, transform 1000ms';

      setInterval(() => {
        // Prepare next image
        nextImg.src = images[nextIndex];
        
        // Bring next image to top (visual) and fade in
        nextImg.style.zIndex = '3';
        // Force reflow
        void nextImg.offsetWidth;
        nextImg.style.opacity = '1';
        
        // After transition completion
        setTimeout(() => {
          // Swap sources: current becomes the new image
          currentImg.src = images[nextIndex];
          
          // Reset "next" image to be ready for the *next* cycle
          nextImg.style.transition = 'none';
          nextImg.style.opacity = '0';
          nextImg.style.zIndex = '1';
          
          void nextImg.offsetWidth;
          nextImg.style.transition = 'opacity 1000ms ease-in-out, transform 1000ms';
          
          currentIndex = nextIndex;
          nextIndex = (nextIndex + 1) % images.length;
        }, 1200);
        
      }, 5000 + Math.random() * 2000); 
    });
  }

  document.addEventListener('astro:page-load', initSlideshows);
  if (document.readyState === 'complete') {
    initSlideshows();
  } else {
    document.addEventListener('DOMContentLoaded', initSlideshows);
  }
</script>
